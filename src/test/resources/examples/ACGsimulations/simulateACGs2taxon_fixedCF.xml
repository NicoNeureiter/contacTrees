<?xml version='1.0' encoding='UTF-8'?>
<beast version="2.8"
       namespace="beast.core:beast.core.util:beast.evolution.alignment:beast.evolution.nuc:beast.evolution.operators:beast.evolution.sitemodel:beast.evolution.substitutionmodel:beast.evolution.tree.coalescent:beast.base.core:beast.base.evolution.alignment:beast.base.evolution.likelihood:beast.base.evolution.operator:beast.base.evolution.sitemodel:beast.base.evolution.substitutionmodel:beast.base.evolution.tree:beast.base.evolution.tree.coalescent:beast.base.inference:beast.base.inference.operator:beast.base.inference.util:beast.pkgmgmt:contactrees:contactrees.model:contactrees.util">
  
    <run spec="ACGSimulator" nSims="$(nSims)">
	    <simACG spec="SimulatedACGWithBlocks" id="acgWithBlocks" conversionRate="$(convRate)" moveProb="$(moveProb)">
	       <network spec="ConversionGraph" id="acg">
	        <taxonset spec="TaxonSet">
	            <taxon spec="Taxon" id="A"/>
	            <taxon spec="Taxon" id="B"/>
	        </taxonset>
	       </network>
	   	<blockSet spec="BlockSet" id="blockSet" network="@acg">
       		<block spec="Block" id="block.0"/>
       		<block spec="Block" id="block.1"/>
       		<block spec="Block" id="block.2"/>
       		<block spec="Block" id="block.3"/>
       		<block spec="Block" id="block.4"/>
       		<block spec="Block" id="block.5"/>
       		<block spec="Block" id="block.6"/>
       		<block spec="Block" id="block.7"/>
       		<block spec="Block" id="block.8"/>
       		<block spec="Block" id="block.9"/>  
	   		<!-- 
	   		<plate var="n" range="$(blocks)">
	   			<block spec="Block" id="$(n)"/>
	   		</plate>
	   		 -->
	   	</blockSet>
        <populationModel spec="beast.base.spec.evolution.tree.coalescent.ConstantPopulation" popSize="$(popSize)"/>
        <clonalFrame spec="TreeParser" newick="(1:2.0,2:2.0):0.0;"/>
	    </simACG>
         
	    <logger logEvery="1" fileName="$(filebase).trees">
	        <log spec="ACGWithMetaDataLogger" network="@acg" blockSet="@blockSet"/>
	    </logger>
    </run>
  
</beast>
